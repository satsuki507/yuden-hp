---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm';
---

<Layout title="お問い合わせ | 優伸電設株式会社">
    <header class="border-b border-gray-200 bg-white sticky top-0 z-50 shadow-sm">
        <div class="max-w-screen-xl mx-auto px-4 h-20 flex justify-between items-center">
            <div class="flex items-center gap-2">
                <a href="/" class="flex items-center gap-2 hover:opacity-80 transition">
                    <img src="/images/YUDENロゴ_2_1_ol.png" alt="YD" class="h-11" onerror="this.style.display='none';this.insertAdjacentHTML('afterend', '<span class=\'font-black text-2xl text-primary-900\'>YD</span>')">
                    <span class="text-xl md:text-2xl text-gray-600 font-medium">優伸電設株式会社</span>
                </a>
            </div>
            <a href="/" class="bg-gray-100 text-gray-600 text-base font-bold px-5 py-2.5 rounded hover:bg-gray-200 transition flex items-center gap-1">
                <span class="material-icons-round text-base">arrow_back</span> TOPへ戻る
            </a>
        </div>
    </header>

    <div class="bg-primary-900 py-12 text-center text-white">
        <h1 class="text-3xl font-bold mb-2">お問い合わせ</h1>
        <p class="text-primary-50 text-sm tracking-widest">CONTACT</p>
    </div>

    <main class="flex-grow py-16 px-4">
        <div class="max-w-screen-lg mx-auto">
            <div class="text-lg grid md:grid-cols-2 gap-12">
                <div>
                    <h2 class="text-2xl font-bold text-gray-800 mb-6 border-b-4 border-primary inline-block pb-1">
                        お電話でのお問い合わせ
                    </h2>
                    <p class="text-gray-600 mb-8 leading-relaxed">
                        お急ぎの方や、フォーム入力が面倒な方は、お気軽にお電話ください。<br>
                        「ホームページを見た」とお伝えいただけるとスムーズです。
                    </p>
                    <div class="bg-white p-8 rounded-lg shadow-sm border border-gray-200 text-center mb-8">
                        <p class="text-base text-gray-500 font-bold mb-2">TEL</p>
                        <a href="tel:0422265124" class="text-3xl md:text-4xl font-bold text-primary hover:text-accent transition block mb-2">
                            0422-26-5124
                        </a>
                        <p class="text-base text-gray-400">受付時間 8:00〜17:00（日・祝除く）</p>
                    </div>
                    <div class="bg-gray-100 p-6 rounded text-base text-gray-600">
                        <p class="font-bold mb-2">FAXでのお問い合わせ</p>
                        <p class="text-xl font-bold">0422-24-9971</p>
                    </div>
                </div>

                <div>
                    <h2 class="text-2xl font-bold text-gray-800 mb-6 border-b-4 border-primary inline-block pb-1">
                        メールフォーム
                    </h2>
                    <ContactForm client:load /> </div>
                </div>
            </div>
        </div>
    </main>

    <Footer />
</Layout>